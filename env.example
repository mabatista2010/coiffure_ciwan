# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_... # Reemplazar con tu clave secreta de Stripe (producción)
STRIPE_WEBHOOK_SECRET=whsec_... # Webhook secret de Stripe (opcional para producción)

# Base URL for Stripe redirects
NEXT_PUBLIC_BASE_URL=http://localhost:3000 # Cambiar a tu dominio en producción

# Supabase Configuration (ya configurado)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key 